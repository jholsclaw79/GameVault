@page "/games/{GameId:long}/achievements"
@using GameVault.Data
@using GameVault.Data.RetroAchievements
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject RetroAchievementsAchievementService RetroAchievementsAchievementService

<PageTitle>@(string.IsNullOrWhiteSpace(GameName) ? "Achievements" : $"{GameName} - Achievements")</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3" Style="gap: 0.5rem; flex-wrap: wrap;">
    <MudText Typo="Typo.h4" GutterBottom="false">Achievements</MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" Href="@($"/games/{GameId}")">
        Back To Game
    </MudButton>
</MudStack>

@if (IsLoading)
{
    <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <MudAlert Severity="Severity.Warning" Dense="true">@ErrorMessage</MudAlert>
}
else
{
    <MudPaper Class="pa-4 mb-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 0.75rem; flex-wrap: wrap;">
            <MudText Typo="Typo.h6">@DisplayGameName</MudText>
            <MudLink Href="@RetroAchievementsGameUrl"
                     Target="_blank"
                     Typo="Typo.body2">
                View on RetroAchievements
            </MudLink>
            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">Completed: @CompletedAchievementsCount / @TotalAchievementsCount</MudChip>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.End" Style="gap: 0.75rem; flex-wrap: wrap;" Class="mt-3">
            <MudSelect T="AchievementFilterOption"
                       Label="Filter"
                       @bind-Value="SelectedFilter"
                       Dense="true"
                       Style="min-width: 180px;">
                <MudSelectItem T="AchievementFilterOption" Value="@AchievementFilterOption.All">All Achievements</MudSelectItem>
                <MudSelectItem T="AchievementFilterOption" Value="@AchievementFilterOption.Completed">Completed</MudSelectItem>
                <MudSelectItem T="AchievementFilterOption" Value="@AchievementFilterOption.NotCompleted">Not Completed</MudSelectItem>
            </MudSelect>

            <MudSelect T="AchievementSortField"
                       Label="Sort By"
                       @bind-Value="SelectedSortField"
                       Dense="true"
                       Style="min-width: 150px;">
                <MudSelectItem T="AchievementSortField" Value="@AchievementSortField.Id">ID</MudSelectItem>
                <MudSelectItem T="AchievementSortField" Value="@AchievementSortField.Title">Title</MudSelectItem>
                <MudSelectItem T="AchievementSortField" Value="@AchievementSortField.Points">Points</MudSelectItem>
            </MudSelect>

            <MudSelect T="bool"
                       Label="Direction"
                       @bind-Value="SortDescending"
                       Dense="true"
                       Style="min-width: 140px;">
                <MudSelectItem T="bool" Value="@false">Ascending</MudSelectItem>
                <MudSelectItem T="bool" Value="@true">Descending</MudSelectItem>
            </MudSelect>

            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetFiltersAndSort">
                Reset
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (VisibleAchievements.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">No achievements match the current filter.</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (RetroAchievementsAchievementService.GameAchievementCard achievement in VisibleAchievements)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Class="achievement-card h-100"
                             Style="@(achievement.IsUnlocked ? "background-color: rgba(46, 125, 50, 0.45); border: 1px solid rgba(129, 199, 132, 0.85);" : string.Empty)">
                        @if (!string.IsNullOrWhiteSpace(GetBadgeUrl(achievement.BadgeName)))
                        {
                            <MudCardMedia Image="@GetBadgeUrl(achievement.BadgeName)" Height="140" />
                        }
                        <MudCardContent>
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1" Style="gap: 0.5rem;">
                                <MudText Typo="Typo.subtitle1">@achievement.Title</MudText>
                                <MudChip T="string"
                                         Color="@(achievement.IsUnlocked ? Color.Success : Color.Default)"
                                         Variant="Variant.Outlined"
                                         Size="Size.Small">
                                    @(achievement.IsUnlocked ? "Unlocked" : "Locked")
                                </MudChip>
                            </MudStack>
                            <MudText Typo="Typo.caption" Class="d-block mb-2">ID: @achievement.Id</MudText>
                            <MudText Typo="Typo.body2" Class="mb-2">@achievement.Description</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@achievement.Points pts</MudChip>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}
