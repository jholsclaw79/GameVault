@page "/systems/{PlatformId:long}"
@using GameVault.Data
@using GameVault.Data.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbContextFactory

<PageTitle>System</PageTitle>

@if (IsLoading)
{
    <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
}
else if (Platform == null)
{
    <MudAlert Severity="Severity.Warning" Dense="true">
        System not found.
    </MudAlert>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudText Typo="Typo.h4">@Platform.Name</MudText>
        <MudStack Row="true" Spacing="1">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="ProcessGames"
                       Disabled="@IsProcessingGames">
                Process Games
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="OpenEditSystemModal">
                Edit System
            </MudButton>
        </MudStack>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(ProcessResultMessage))
    {
        <MudAlert Class="mb-3" Severity="@(LastProcessSucceeded ? Severity.Success : Severity.Warning)" Dense="true">
            @ProcessResultMessage
        </MudAlert>
    }
    
    @if (IsProcessingGames || !string.IsNullOrWhiteSpace(CurrentProcessStep))
    {
        <MudPaper Class="pa-3 mb-3" Outlined="true">
            <MudText Typo="Typo.body2" Class="mb-1">
                @(string.IsNullOrWhiteSpace(CurrentProcessStep) ? "Preparing..." : CurrentProcessStep)
            </MudText>
            @if (CurrentProcessPercent.HasValue)
            {
                <MudProgressLinear Color="Color.Info" Value="@CurrentProcessPercent.Value" />
                <MudText Typo="Typo.caption" Class="mt-1">@CurrentProcessPercent.Value%</MudText>
            }
            else
            {
                <MudProgressLinear Color="Color.Info" Indeterminate="true" />
            }
        </MudPaper>
    }

    <MudText Typo="Typo.body2" Class="mb-3">
        <b>ROM Folder:</b> @(string.IsNullOrWhiteSpace(Platform.RomFolder) ? "Not set" : Platform.RomFolder)
        
    </MudText>
    <MudText Typo="Typo.body2" Class="mb-3">
        <b>Rom Types:</b> @(string.IsNullOrWhiteSpace(Platform.RomTypes) ? "Not set" : Platform.RomTypes)
    </MudText>

    <MudText Typo="Typo.h5" GutterBottom="true">Versions</MudText>
    @if (!PlatformVersions.Any())
    {
        <MudPaper Class="pa-4 mb-3">
            <MudGrid>
                <MudItem xs="12" md="3">
                    @if (!string.IsNullOrWhiteSpace(LogoUrl))
                    {
                        <MudPaper Class="pa-3 d-flex align-center justify-center" Style="background-color: white; min-height: 180px;" Outlined="true">
                            <MudImage Src="@LogoUrl" Alt="@Platform.Name" Fluid="true" Style="max-height: 160px; object-fit: contain;" />
                        </MudPaper>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">No logo available</MudAlert>
                    }
                </MudItem>
                <MudItem xs="12" md="9">
                    <MudText Typo="Typo.body1"><b>Abbreviation:</b> @(Platform.Abbreviation ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>Generation:</b> @(Platform.Generation?.ToString() ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>Type:</b> @(Platform.PlatformType?.Name ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>Family:</b> @(Platform.PlatformFamily?.Name ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1">
                        <b>URL: </b>
                        @if (string.IsNullOrWhiteSpace(Platform.Url))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            <MudLink Href="@Platform.Url" Target="_blank">@Platform.Url</MudLink>
                        }
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudAlert Severity="Severity.Info" Dense="true">
            No platform versions were found for this system.
        </MudAlert>
    }
    else if (HasSingleVersion)
    {
        GVPlatformVersion version = PlatformVersions[0];
        string? versionLogoUrl = GetPlatformVersionLogoUrl(version);

        <MudPaper Class="pa-4">
            <MudGrid>
                <MudItem xs="12" md="3">
                    @if (!string.IsNullOrWhiteSpace(versionLogoUrl))
                    {
                        <MudPaper Class="pa-3 d-flex align-center justify-center" Style="background-color: white; min-height: 180px;" Outlined="true">
                            <MudImage Src="@versionLogoUrl" Alt="@version.Name" Fluid="true" Style="max-height: 160px; object-fit: contain;" />
                        </MudPaper>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">No version logo available</MudAlert>
                    }
                </MudItem>
                <MudItem xs="12" md="9">
                    <MudText Typo="Typo.h6" GutterBottom="true">@version.Name</MudText>
                    <MudText Typo="Typo.body1"><b>Slug:</b> @(version.Slug ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>CPU:</b> @(version.CPU ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>Memory:</b> @(version.Memory ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>Storage:</b> @(version.Storage ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1"><b>OS:</b> @(version.OS ?? "N/A")</MudText>
                    <MudText Typo="Typo.body1">
                        <b>URL: </b>
                        @if (string.IsNullOrWhiteSpace(Platform.Url))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            <MudLink Href="@version.Url" Target="_blank">@version.Url</MudLink>
                        }
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-2">@(version.Summary ?? "No summary available.")</MudText>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }
    else if (HasMultipleVersions)
    {
        @if (CurrentVersion != null)
        {
            string? versionLogoUrl = GetPlatformVersionLogoUrl(CurrentVersion);

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="Color.Default" OnClick="ShowPreviousVersion" aria-label="Previous version" />
                <MudText Typo="Typo.subtitle1">
                    @CurrentVersion.Name (@(CurrentVersionIndex + 1)/@PlatformVersions.Count)
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" OnClick="ShowNextVersion" aria-label="Next version" />
            </MudStack>

            <MudStack Row="true" Class="mb-3" Style="gap: 0.25rem; flex-wrap: wrap;" AlignItems="AlignItems.Center" Justify="Justify.Center">
                @for (int i = 0; i < PlatformVersions.Count; i++)
                {
                    int versionIndex = i;
                    <MudIconButton
                        Icon="@(versionIndex == CurrentVersionIndex ? Icons.Material.Filled.RadioButtonChecked : Icons.Material.Filled.RadioButtonUnchecked)"
                        Color="@(versionIndex == CurrentVersionIndex ? Color.Primary : Color.Default)"
                        Size="Size.Small"
                        OnClick="@(() => SelectVersion(versionIndex))"
                        aria-label="@($"Go to version {versionIndex + 1}")" />
                }
            </MudStack>

            <MudPaper Class="pa-4 version-slide" Style="min-height: 100%;">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        @if (!string.IsNullOrWhiteSpace(versionLogoUrl))
                        {
                            <MudPaper Class="pa-3 d-flex align-center justify-center" Style="background-color: white; min-height: 180px;" Outlined="true">
                                <MudImage Src="@versionLogoUrl" Alt="@CurrentVersion.Name" Fluid="true" Style="max-height: 160px; object-fit: contain;" />
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No version logo available</MudAlert>
                        }
                    </MudItem>
                    <MudItem xs="12" md="9">
                        <MudText Typo="Typo.h6" GutterBottom="true">@CurrentVersion.Name</MudText>
                        <MudText Typo="Typo.body1"><b>Slug:</b> @(CurrentVersion.Slug ?? "N/A")</MudText>
                        <MudText Typo="Typo.body1"><b>CPU:</b> @(CurrentVersion.CPU ?? "N/A")</MudText>
                        <MudText Typo="Typo.body1"><b>Memory:</b> @(CurrentVersion.Memory ?? "N/A")</MudText>
                        <MudText Typo="Typo.body1"><b>Storage:</b> @(CurrentVersion.Storage ?? "N/A")</MudText>
                        <MudText Typo="Typo.body1"><b>OS:</b> @(CurrentVersion.OS ?? "N/A")</MudText>
                        <MudText Typo="Typo.body1">
                            <b>URL: </b>
                            @if (string.IsNullOrWhiteSpace(CurrentVersion.Url))
                            {
                                <span>N/A</span>
                            }
                            else
                            {
                                <MudLink Href="@CurrentVersion.Url" Target="_blank">@CurrentVersion.Url</MudLink>
                            }
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">@(CurrentVersion.Summary ?? "No summary available.")</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }
    }

    <MudText Typo="Typo.h5" GutterBottom="true" Class="mt-4">Games</MudText>
    <MudTabs Rounded="true" Elevation="1">
        <MudTabPanel Text="@($"Matched ({MatchedGames.Count})")">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Verified games that exist in both the IGDB database and your library.
            </MudAlert>
            @if (!MatchedGames.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No matched games found for this system.
                </MudAlert>
            }
            else
            {
                <div class="games-grid">
                    @foreach (GVGame game in MatchedGames)
                    {
                        <GameCard Game="game" />
                    }
                </div>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Missing ({MissingGames.Count})")">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Games found in IGDB based on your filters, but not currently in your collection.
            </MudAlert>
            @if (!MissingGames.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No missing games found for this system.
                </MudAlert>
            }
            else
            {
                <div class="games-grid">
                    @foreach (GVGame game in MissingGames)
                    {
                        <GameCard Game="game" />
                    }
                </div>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Unknown ({UnknownGames.Count})")">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Local files or manual entries that couldn't be linked to an IGDB profile.
            </MudAlert>
            @if (!UnknownGames.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No unknown games found for this system.
                </MudAlert>
            }
            else
            {
                <div class="games-grid">
                    @foreach (GVGame game in UnknownGames)
                    {
                        <GameCard Game="game" />
                    }
                </div>
            }
        </MudTabPanel>
    </MudTabs>
}
