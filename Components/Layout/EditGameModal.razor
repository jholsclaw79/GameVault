<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Edit Game</MudText>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@ErrorMessage</MudAlert>
            }

            <MudTextField T="string" Label="Game" Value="@GameName" ReadOnly="true" FullWidth="true" />

            <MudNumericField T="long?"
                             Label="IGDB ID"
                             @bind-Value="IgdbIdInput"
                             Min="1"
                             HideSpinButtons="true"
                             FullWidth="true"
                             Clearable="true" />

            <MudSelect T="long?"
                       Label="System (for ROM Location)"
                       Value="SelectedPlatformIgdbId"
                       ValueChanged="OnSelectedPlatformChanged"
                       FullWidth="true"
                       Clearable="true">
                @foreach (GameEditSystemOption option in SystemOptions)
                {
                    <MudSelectItem T="long?" Value="@option.PlatformIgdbId">@option.PlatformName</MudSelectItem>
                }
            </MudSelect>

            <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                <MudTextField T="string"
                              Label="ROM Location"
                              Value="@RomLocationInput"
                              ReadOnly="true"
                              FullWidth="true"
                              Placeholder="Select a ROM file" />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           OnClick="OpenRomFileSelector"
                           Disabled="@(!SelectedPlatformIgdbId.HasValue)">
                    Browse
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Color="Color.Secondary"
                           OnClick="@(() => RomLocationInput = string.Empty)"
                           Disabled="@(!SelectedPlatformIgdbId.HasValue)">
                    Clear
                </MudButton>
            </MudStack>

            <MudNumericField T="long?"
                             Label="RetroAchievements Game ID (Selected System)"
                             @bind-Value="RetroAchievementsGameIdInput"
                             Min="1"
                             HideSpinButtons="true"
                             FullWidth="true"
                             Clearable="true"
                             Disabled="@(!SelectedPlatformIgdbId.HasValue)" />

            <MudCheckBox T="bool" @bind-Value="IsCompletedInput" Label="Completed (Selected System)" Disabled="@(!SelectedPlatformIgdbId.HasValue)" />
            <MudCheckBox T="bool" @bind-Value="IsPhysicallyOwnedInput" Label="Physically Owned (Selected System)" Disabled="@(!SelectedPlatformIgdbId.HasValue)" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Close" Disabled="@IsSaving">
            Cancel
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@IsSaving">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
