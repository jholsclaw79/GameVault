@inject IDialogService DialogService

<MudNavMenu Color="Color.Success" Bordered="true">

    <MudLink Href="/" Class="d-flex align-center mud-text-secondary" Style="padding-top:5px;">
        <img src="images/logo.png" alt="GameVault" style="height: 50px; cursor: pointer;"/>
    </MudLink>

    <MudDivider Class="my-2"/>

    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>

    <MudNavLink Icon="@Icons.Material.Filled.AddCircleOutline" OnClick="OpenAddTrackedSystemModal">
        Add Tracked System
    </MudNavLink>

    @if (TrackedPlatforms.Any())
    {
        <MudDivider Class="my-2"/>
        <MudText Typo="Typo.caption" Class="px-4 py-1 mud-text-secondary">Tracked Systems</MudText>

        @foreach (var trackedPlatform in TrackedPlatforms)
        {
            <MudNavLink Href="@($"/systems/{trackedPlatform.Id}")" Icon="@Icons.Material.Filled.VideogameAsset">
                @trackedPlatform.Name
            </MudNavLink>
        }
    }


    <MudDivider Class="my-2"/>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Info"
               StartIcon="@Icons.Material.Filled.Sync"
               FullWidth="true"
               OnClick="OpenSyncModal">
        Sync IGDB Data
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Info"
               StartIcon="@Icons.Material.Filled.Sync"
               FullWidth="true"
               Class="mt-2"
               OnClick="OpenRetroAchievementsSyncModal">
        Sync RetroAchievements Data
    </MudButton>
</MudNavMenu>
