<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet class="mud-paper mud-elevation-10 mud-rounded-lg">
    <div class="components-reconnect-container">
        
        <div class="components-rejoining-animation" aria-hidden="true">
            <div class="mud-border-primary"></div>
            <div class="mud-border-primary"></div>
        </div>
        
        <div class="mud-text-primary mud-typography-h6 text-center">
            <p class="components-reconnect-first-attempt-visible">
                Rejoining the server...
            </p>
            <p class="components-reconnect-repeated-attempt-visible">
                Rejoin failed... retrying in <span id="components-seconds-to-next-attempt" class="mud-text-secondary"></span>s.
            </p>
            <p class="components-reconnect-failed-visible mud-text-error">
                Failed to rejoin.<br/>Please retry or reload.
            </p>
            <p class="components-pause-visible">
                Session paused by server.
            </p>
            <p class="components-resume-failed-visible mud-text-error">
                Failed to resume session.
            </p>
        </div>
        
        <button id="components-reconnect-button" 
                class="components-reconnect-failed-visible mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-filled-size-medium mud-ripple">
            <span class="mud-button-label">Retry</span>
        </button>

        <button id="components-resume-button" 
                class="components-pause-visible components-resume-failed-visible mud-button-root mud-button mud-button-filled mud-button-filled-secondary mud-ripple">
            <span class="mud-button-label">Resume</span>
        </button>
    </div>
</dialog>