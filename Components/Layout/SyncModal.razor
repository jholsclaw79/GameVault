@using GameVault.Data.IGDB
@using GameVault.Data.RetroAchievements
@inject IGDBPlatformTypeService PlatformTypeService
@inject IGDBPlatformFamilyService PlatformFamilyService
@inject IGDBPlatformLogoService PlatformLogoService
@inject IGDBPlatformVersionService PlatformVersionService
@inject IGDBPlatformVersionReleaseDateService PlatformVersionReleaseDateService
@inject IGDBPlatformService PlatformService
@inject IGDBCompanyService CompanyService
@inject IGDBLanguageService LanguageService
@inject IGDBGameTypeService GameTypeService
@inject RetroAchievementsSyncService RetroAchievementsSyncService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
        @if (!_syncComplete)
        {
            <MudIcon Icon="@Icons.Material.Filled.Sync" Color="Color.Info" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h5" GutterBottom="true">Updating System Data</MudText>

            <MudProgressLinear Value="_progress" Class="my-4" />
            <div Class="mt-6 d-flex align-center justify-space-between">
                <MudText Typo="Typo.body1">@_currentItemName</MudText>
                @if (_showSyncedCount)
                {
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">@($"{_currentItemSynced:N0} synced")</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined">Working...</MudChip>
                }
            </div>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h5" Color="Color.Success" GutterBottom="true">Sync Complete</MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                @_syncSummary
            </MudText>
        }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!_syncComplete)" OnClick="Close">
            Done
        </MudButton>
    </DialogActions>
</MudDialog>
