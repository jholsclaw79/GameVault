@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject IJSRuntime JS
@using GameVault.Data 
@inject DbHealthService DbHealth

<MudThemeProvider Theme="_draculaTheme" IsDarkMode="true" />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_hasCheckedConnection && !_isDbConnected)
{
    @* FULL SCREEN LOCKOUT *@
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
        <MudPaper Elevation="9" Class="pa-10 text-center" Style="border: 2px solid var(--mud-palette-error);">
            <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Error" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.h4" Color="Color.Error" GutterBottom="true">Connection Failed</MudText>
            <MudText Typo="Typo.body1" Class="mb-6">
                GameVault is unable to reach the MySQL database. 
                Please check your server status or environment credentials.
            </MudText>
            <MudText Typo="Typo.caption" Style="opacity: 0.6;">
                Redeploy the Docker instance with the correct MySQL credentials to continue
            </MudText>
        </MudPaper>
    </MudContainer>
}
else if (!_hasCheckedConnection)
{
    @* INITIAL LOADING STATE *@
    <MudContainer Class="d-flex align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" />
    </MudContainer>
}
else
{
    @* NORMAL APP - Only renders if DB is connected *@
    <MudLayout>
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudAppBar Elevation="1">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Secondary" Edge="Edge.Start" OnClick="@DrawerToggle" />
                <MudText Typo="Typo.h6" Class="ml-3">GameVault</MudText>
            </MudAppBar>
        </MudHidden>
        
        <MudDrawer @bind-Open="_drawerOpen" Elevation="2" Breakpoint="Breakpoint.Md" Variant="@DrawerVariant.Responsive">
            <NavMenu />
        </MudDrawer>

        <MudMainContent>
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 px-8">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}